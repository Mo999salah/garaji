{
  "expo": {
    "name": "Garaji",
    "slug": "garaji",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "garaji",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#C89B3C",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Tajawal-Regular.ttf",
            "./assets/fonts/Tajawal-Medium.ttf",
            "./assets/fonts/Tajawal-Bold.ttf",
            "./assets/fonts/Tajawal-ExtraBold.ttf",
            "./assets/fonts/Tajawal-Black.ttf"
          ],
          "android": {
            "fonts": [
              {
                "fontFamily": "Tajawal",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Tajawal-Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/Tajawal-Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "./assets/fonts/Tajawal-Bold.ttf",
                    "weight": 700
                  },
                  {
                    "path": "./assets/fonts/Tajawal-ExtraBold.ttf",
                    "weight": 800
                  },
                  {
                    "path": "./assets/fonts/Tajawal-Black.ttf",
                    "weight": 900
                  }
                ]
              }
            ]
          }
        }
      ]
    ]
  }
}
