{
  "expo": {
    "name": "Garaji",
    "slug": "garaji",
    "owner": "mo999salah",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "garaji",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mo999salah.garaji",
      "infoPlist": {
        "NSCameraUsageDescription": "نحتاج الوصول إلى الكاميرا لتصوير استمارة المركبة أو موقع الخدمة.",
        "NSLocationWhenInUseUsageDescription": "نستخدم موقعك لمساعدتك على اختيار أقرب فرع وتحديد موقع خدمة الصيانة المتنقلة.",
        "NSPhotoLibraryUsageDescription": "نحتاج الوصول إلى الصور لإرفاق صورة استمارة المركبة أو صورة المركبة.",
        "NSUserNotificationsUsageDescription": "نرسل لك تنبيهات عند تحديث حالة طلب الصيانة."
      }
    },
    "android": {
      "package": "com.mo999salah.garaji",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "POST_NOTIFICATIONS"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#C89B3C",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Tajawal-Regular.ttf",
            "./assets/fonts/Tajawal-Medium.ttf",
            "./assets/fonts/Tajawal-Bold.ttf",
            "./assets/fonts/Tajawal-ExtraBold.ttf",
            "./assets/fonts/Tajawal-Black.ttf"
          ],
          "android": {
            "fonts": [
              {
                "fontFamily": "Tajawal",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Tajawal-Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/Tajawal-Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "./assets/fonts/Tajawal-Bold.ttf",
                    "weight": 700
                  },
                  {
                    "path": "./assets/fonts/Tajawal-ExtraBold.ttf",
                    "weight": 800
                  },
                  {
                    "path": "./assets/fonts/Tajawal-Black.ttf",
                    "weight": 900
                  }
                ]
              }
            ]
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    }
  }
}
